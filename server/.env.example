# ── Backend Configuration (Render / Server) ──

PORT=5000

# Connection string for MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/database

# Google AI Studio API key from https://aistudio.google.com/apikey
# Free tier: 15 req/min, 1M tokens/min
GOOGLE_AI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini model to use for quiz generation
# Options: gemini-2.0-flash (fast), gemini-1.5-flash, gemini-2.5-pro-exp-03-25 (best)
GEMINI_MODEL=gemini-2.0-flash
# The full Firebase Service Account JSON (Must be a single-line string for most hosts)
# Example: {"type": "service_account", "project_id": "...", ...}
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# Comma-separated list of allowed frontend origins (your Vercel URLs)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
