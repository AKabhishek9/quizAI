# ── Backend Configuration (Render / Server) ──

PORT=5000

# Connection string for MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/database

# OpenRouter API Key (Primary AI)
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# OpenRouter model to use for quiz generation
# Default: meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Groq API Key (Fallback AI)
# Get from https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq model to use as fallback
GROQ_MODEL=llama-3.1-8b-instant
# The full Firebase Service Account JSON (Must be a single-line string for most hosts)
# Example: {"type": "service_account", "project_id": "...", ...}
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# Comma-separated list of allowed frontend origins (your Vercel URLs)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
