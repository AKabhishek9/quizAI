# ── Backend Configuration (Render / Server) ──

PORT=5000

# Connection string for MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/database

# ── AI Configuration ──
# Primary AI Provider (Default: OpenRouter)
API_KEY_1=your_primary_api_key_here
MODEL_1=llama-3.3-70b-versatile
# Optional: Change BASE_URL_1 if using a provider other than OpenRouter
# BASE_URL_1=https://openrouter.ai/api/v1

# Secondary Fallback AI Provider (Default: Groq)
API_KEY_2=your_secondary_api_key_here
MODEL_2=llama-3.3-70b-versatile
# Optional: Change BASE_URL_2 if using a provider other than Groq
# BASE_URL_2=https://api.groq.com/openai/v1
# The full Firebase Service Account JSON (Must be a single-line string for most hosts)
# Example: {"type": "service_account", "project_id": "...", ...}
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# Comma-separated list of allowed frontend origins (your Vercel URLs)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
